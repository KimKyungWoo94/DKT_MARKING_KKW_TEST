# ============================================================
#  Visual Studio / .NET  —  EzInaFlex2.0 솔루션용 .gitignore
# ============================================================

# ──────────────────────────────────────────────────────────
# 1. Visual Studio 로컬 캐시 / IDE 설정
# ──────────────────────────────────────────────────────────
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser

# ──────────────────────────────────────────────────────────
# 2. 빌드 산출물 (모든 프로젝트 폴더 공통)
# ──────────────────────────────────────────────────────────
[Dd]ebug/
[Rr]elease/
[Xx]64/
[Xx]86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
[Bb]ld/
[Oo]bj/
[Oo]ut/
[Ll]og/

# 솔루션 루트의 bin 폴더 (빌드 복사본)
/bin/

# ──────────────────────────────────────────────────────────
# 3. NuGet 패키지
#    packages.config는 커밋, 실제 패키지 다운로드 폴더는 제외
#    (nuget restore 또는 msbuild /t:Restore 로 복원 가능)
# ──────────────────────────────────────────────────────────
/packages/
*.nupkg
*.snupkg
!DLL/**           # DLL 폴더는 서드파티 SDK 포함 → 커밋 유지

# ──────────────────────────────────────────────────────────
# 4. NuGet 실행 파일 (소스 관리 불필요)
# ──────────────────────────────────────────────────────────
/nuget.exe

# ──────────────────────────────────────────────────────────
# 5. 압축/배포 아카이브
# ──────────────────────────────────────────────────────────
*.zip
*.7z
*.tar
*.rar

# ──────────────────────────────────────────────────────────
# 6. 런타임 로그 / 덤프
# ──────────────────────────────────────────────────────────
*.log
*.log.*
*.dmp
*.tmp
TestResults/
*.trx
*.coverage
*.coveragexml

# ──────────────────────────────────────────────────────────
# 7. 민감 정보 (DB 연결 문자열, 비밀번호 등)
#    실서버 값이 들어간 설정 파일은 올리지 않도록 주의
# ──────────────────────────────────────────────────────────
*.env
*secret*
*Secret*
# app.config / app.*.config 중 실서버 설정본이 있다면 아래 주석 해제
# app.Release.config
# app.Production.config

# ──────────────────────────────────────────────────────────
# 8. .NET 빌드 관련 기타
# ──────────────────────────────────────────────────────────
project.lock.json
project.fragment.lock.json
artifacts/
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp_proj
*_wpftmp.csproj
*.vspscc
*.vssscc

# ──────────────────────────────────────────────────────────
# 9. ReSharper / Rider
# ──────────────────────────────────────────────────────────
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# ──────────────────────────────────────────────────────────
# 10. Windows OS 메타
# ──────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
